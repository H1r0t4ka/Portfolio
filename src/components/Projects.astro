---

<section id="proyectos" class="bg-white dark:bg-[#1E1E1E] rounded-3xl shadow-xl p-6 md:p-12 max-w-6xl mx-auto scroll-mt-40 transition-colors duration-500 ease-in-out">
  <h2 class="text-2xl font-bold text-center mb-10 text-[#1E1E1E] dark:text-white">
    {translateLabels('projects.title')}
  </h2>

  <div class="relative">
    <div
      id="projects-carousel"
      class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory touch-pan-x overscroll-x-contain px-2 sm:px-4 py-10"
      style="-webkit-overflow-scrolling: touch;"
      tabindex="0"
      aria-label="Carrusel de proyectos"
    >
      {projects.map((project, index) => (
        <article
          data-carousel-item
          data-index={index}
          class="snap-start flex-none w-[85%] sm:w-[70%] md:w-[48%] lg:w-[32%] rounded-2xl border dark:bg-[#1E1E1E] border-gray-200 dark:border-gray-700 dark:shadow-[0_0_30px_#A855F7] p-4 flex flex-col justify-between"
        >

        <!-- Header -->
        <header class="flex justify-between items-center mb-3">
          <h3 class="font-semibold text-lg text-[#1E1E1E]">
            {translateLabels(project.titleKey)}
          </h3>
          <span class="text-sm text-[#1E1E1E] dark:text-white">{project.date}</span>
        </header>

        <!-- Imagen -->
        <img
          src={project.image}
          alt={translateLabels(project.titleKey)}
          class="rounded-xl object-cover w-full h-64 mb-4"
          loading="lazy"
        />

        <!-- Descripción -->
        <p class="text-gray-600 text-sm leading-relaxed mb-3">
          {translateLabels(project.descriptionKey)}
        </p>

        <!-- Footer de la card -->
<div class="flex justify-between items-center mt-4 text-sm">
  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {project.tags.map((tag) => (
      <span
        class="px-2 py-0.5 bg-purple-100 text-purple-600 rounded-full text-xs font-medium"
      >
        {tag}
      </span>
    ))}
  </div>

  <!-- Enlaces -->
  <div class="flex items-center gap-3 text-gray-500">
    {project.site && (
      <a
        href={project.site}
        target="_blank"
        class="hover:text-purple-600 transition-colors"
        aria-label="Ver sitio"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 13v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
          <polyline points="15 3 21 3 21 9" />
          <line x1="10" y1="14" x2="21" y2="3" />
        </svg>
      </a>
    )}
    {project.code && (
      <a
        href={project.code}
        target="_blank"
        class="hover:text-purple-600 transition-colors"
        aria-label="Ver código"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M16 18l6-6-6-6" />
          <path d="M8 6l-6 6 6 6" />
        </svg>
      </a>
    )}
  </div>
</div>
        </article>
      ))}
    </div>
    <div
      id="projects-indicator"
      class="flex justify-center gap-2 mt-2"
      aria-label="Indicador de proyectos"
    >
      {projects.map((_, index) => (
        <span
          data-project-dot
          data-index={index}
          class="w-2.5 h-2.5 rounded-full bg-gray-300 dark:bg-gray-700 transition-colors"
        />
      ))}
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const carousel = document.getElementById("projects-carousel");
    if (!carousel) return;

    const el = carousel;
    const items = Array.from(el.querySelectorAll("[data-carousel-item]"));
    const indicatorRoot = document.getElementById("projects-indicator");
    const dots = indicatorRoot
      ? Array.from(indicatorRoot.querySelectorAll("[data-project-dot]"))
      : [];

    const getCurrentIndex = () => {
      if (items.length === 0) return 0;
      const left = el.scrollLeft;
      let closest = 0;
      let min = Infinity;
      for (let i = 0; i < items.length; i++) {
        const dist = Math.abs(items[i].offsetLeft - left);
        if (dist < min) {
          min = dist;
          closest = i;
        }
      }
      return closest;
    };

    const setActive = (index) => {
      for (let i = 0; i < dots.length; i++) {
        const isActive = i === index;
        dots[i].classList.toggle("bg-purple-600", isActive);
        dots[i].classList.toggle("dark:bg-purple-500", isActive);
        dots[i].classList.toggle("bg-gray-300", !isActive);
        dots[i].classList.toggle("dark:bg-gray-700", !isActive);
      }
    };

    let activeRaf = 0;
    const updateActive = () => {
      if (activeRaf) return;
      activeRaf = requestAnimationFrame(() => {
        activeRaf = 0;
        setActive(getCurrentIndex());
      });
    };

    el.addEventListener("scroll", updateActive, { passive: true });
    window.addEventListener("resize", updateActive, { passive: true });
    updateActive();

    if (!("matchMedia" in window) || !window.matchMedia("(pointer: fine)").matches) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    let direction = 0;
    let intensity = 0;
    let raf = 0;
    let isActive = false;

    const start = () => {
      if (isActive) return;
      isActive = true;
      el.style.scrollSnapType = "none";
      el.style.scrollBehavior = "auto";
    };

    const stop = () => {
      direction = 0;
      intensity = 0;
      if (!isActive) return;
      isActive = false;
      el.style.scrollSnapType = "";
      el.style.scrollBehavior = "";
    };

    const tick = () => {
      raf = 0;
      if (direction === 0 || intensity <= 0) {
        stop();
        return;
      }
      const delta = direction * Math.round(1 + intensity * 5);
      el.scrollLeft += delta;
      raf = requestAnimationFrame(tick);
    };

    const setMotion = (nextDirection, nextIntensity) => {
      direction = nextDirection;
      intensity = nextIntensity;
      if (direction === 0 || intensity <= 0) {
        stop();
        return;
      }
      start();
      if (!raf && direction !== 0 && intensity > 0) raf = requestAnimationFrame(tick);
    };

    const onMove = (event) => {
      const rect = el.getBoundingClientRect();
      const x = (event.clientX - rect.left) / rect.width;

      if (x <= 0.22) {
        const t = Math.min(1, (0.22 - x) / 0.22);
        setMotion(-1, t);
        return;
      }

      if (x >= 0.78) {
        const t = Math.min(1, (x - 0.78) / 0.22);
        setMotion(1, t);
        return;
      }

      setMotion(0, 0);
    };

    el.addEventListener("mousemove", onMove, { passive: true });
    el.addEventListener("mouseleave", stop, { passive: true });
    el.addEventListener("blur", stop, { passive: true });
  });
</script>
